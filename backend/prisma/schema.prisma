generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id               Int      @id @default(autoincrement())
  name             String
  cui              String?
  email            String
  subscriptionPlan String   @default("trial")
  createdAt        DateTime @default(now())
  users            User[]
  clients          Client[]
  invoiceSeries    InvoiceSeries[]
  invoices         Invoice[]
  documents         Document[]
  clientUploadLinks ClientUploadLink[]
}

model User {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  email     String   @unique
  password  String
  role      String   @default("accountant")
  createdAt DateTime @default(now())
}

model Client {
  id            Int      @id @default(autoincrement())
  tenantId      Int
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  companyName   String
  cui           String?
  contactEmail  String
  contactPerson String?
  status        String   @default("active")
  createdAt     DateTime @default(now())
  invoices      Invoice[]
  documents        Document[]
  uploadLink       ClientUploadLink?
}

model InvoiceSeries {
  id         Int      @id @default(autoincrement())
  tenantId   Int
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  prefix     String
  year       Int
  lastNumber Int      @default(0)

  invoices   Invoice[]

  @@unique([tenantId, prefix, year])
}

model Invoice {
  id        Int       @id @default(autoincrement())
  tenantId  Int
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  clientId  Int
  client    Client    @relation(fields: [clientId], references: [id])

  seriesId  Int
  series    InvoiceSeries @relation(fields: [seriesId], references: [id])
  number    Int

  issueDate DateTime  @default(now())
  dueDate   DateTime?
  currency  String    @default("RON")

  status    InvoiceStatus @default(DRAFT)

  subtotal  Decimal   @db.Decimal(12, 2)
  vatTotal  Decimal   @db.Decimal(12, 2)
  total     Decimal   @db.Decimal(12, 2)

  notes     String?

  items     InvoiceItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([seriesId, number])
}

model InvoiceItem {
  id          Int      @id @default(autoincrement())
  invoiceId   Int
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(12, 2)
  vatRate     Decimal  @db.Decimal(5, 2) @default(19)

  lineTotal   Decimal  @db.Decimal(12, 2)
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}

enum DocumentCategory {
  INVOICE
  BANK_STATEMENT
  CONTRACT
  OTHER
}

model Document {
  id           Int              @id @default(autoincrement())
  tenantId     Int
  tenant       Tenant           @relation(fields: [tenantId], references: [id])

  clientId     Int
  client       Client           @relation(fields: [clientId], references: [id])

  category     DocumentCategory @default(OTHER)
  originalName String
  storedName   String           // numele fișierului pe disc (randomizat, ca să evităm coliziuni)
  mimeType     String
  size         Int              // bytes

  uploadedAt   DateTime         @default(now())
}

model ClientUploadLink {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  clientId  Int      @unique
  client    Client   @relation(fields: [clientId], references: [id])

  token     String   @unique @default(uuid())
  createdAt DateTime @default(now())
}