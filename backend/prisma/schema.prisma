generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id               Int      @id @default(autoincrement())
  name             String
  cui              String?
  email            String
  subscriptionPlan String   @default("trial")
  createdAt        DateTime @default(now())
  users            User[]
  clients          Client[]
  invoiceSeries    InvoiceSeries[]
  invoices         Invoice[]
  documents         Document[]
  clientUploadLinks ClientUploadLink[]
  declarationSubmissions DeclarationSubmission[]
}

model User {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  email     String   @unique
  password  String
  role      String   @default("accountant")
  createdAt DateTime @default(now())
}

model Client {
  id             Int             @id @default(autoincrement())
  tenantId       Int
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  companyName    String
  cui            String?
  contactEmail   String
  contactPerson  String?
  status         String          @default("active")
  createdAt      DateTime        @default(now())

  clientType     ClientType      @default(SRL)
  fiscalRegime   FiscalRegime    @default(MICRO)
  isVatPayer     Boolean         @default(false)
  vatPeriodicity VatPeriodicity?
  hasEmployees   Boolean         @default(false)

  invoices           Invoice[]
  documents          Document[]
  uploadLink         ClientUploadLink?
  declarationSubmissions DeclarationSubmission[]

   monthlyFee            Decimal? @db.Decimal(12, 2)
   monthlyFeeVatRate      Decimal? @db.Decimal(5, 2) @default(0)
   monthlyFeeDescription String?  @default("Servicii de contabilitate")
}

model InvoiceSeries {
  id         Int      @id @default(autoincrement())
  tenantId   Int
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  prefix     String
  year       Int
  lastNumber Int      @default(0)

  invoices   Invoice[]

  @@unique([tenantId, prefix, year])
}

model Invoice {
  id        Int       @id @default(autoincrement())
  tenantId  Int
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  clientId  Int
  client    Client    @relation(fields: [clientId], references: [id])

  seriesId  Int
  series    InvoiceSeries @relation(fields: [seriesId], references: [id])
  number    Int

  issueDate DateTime  @default(now())
  dueDate   DateTime?
  currency  String    @default("RON")

  status    InvoiceStatus @default(DRAFT)

  subtotal  Decimal   @db.Decimal(12, 2)
  vatTotal  Decimal   @db.Decimal(12, 2)
  total     Decimal   @db.Decimal(12, 2)

  notes     String?

  items     InvoiceItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([seriesId, number])
}

model InvoiceItem {
  id          Int      @id @default(autoincrement())
  invoiceId   Int
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(12, 2)
  vatRate     Decimal  @db.Decimal(5, 2) @default(19)

  lineTotal   Decimal  @db.Decimal(12, 2)
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}

model Document {
  id           Int              @id @default(autoincrement())
  tenantId     Int
  tenant       Tenant           @relation(fields: [tenantId], references: [id])
  clientId     Int
  client       Client           @relation(fields: [clientId], references: [id])
  category     DocumentCategory @default(OTHER)
  source       DocumentSource   @default(CLIENT_UPLOAD)
  originalName String
  storedName   String
  mimeType     String
  size         Int
  uploadedAt   DateTime         @default(now())
}

model ClientUploadLink {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  clientId  Int      @unique
  client    Client   @relation(fields: [clientId], references: [id])

  token     String   @unique @default(uuid())
  createdAt DateTime @default(now())
}

enum DocumentCategory {
  INVOICE
  BANK_STATEMENT
  CONTRACT
  CI_ADMINISTRATOR
  ACTE_INFIINTARE
  DECLARATII
  ADEVERINTE
  PONTAJE
  STATE_SALARII
  BILANT
  OTHER
}

enum DocumentSource {
  CLIENT_UPLOAD
  INTERNAL
}

enum ClientType {
  SRL
  PFA
}

enum FiscalRegime {
  MICRO
  PROFIT
  REAL
  NORMA_VENIT
}

enum VatPeriodicity {
  MONTHLY
  QUARTERLY
}

enum DeclarationType {
  D100
  D101
  BILANT
  D300
  D390
  D394
  D112
  D212
  D205
}

model DeclarationSubmission {
  id              Int             @id @default(autoincrement())
  tenantId        Int
  tenant          Tenant          @relation(fields: [tenantId], references: [id])

  clientId        Int
  client          Client          @relation(fields: [clientId], references: [id])

  declarationType DeclarationType
  month           Int
  year            Int
  submitted       Boolean         @default(false)
  submittedAt     DateTime?

  @@unique([clientId, declarationType, month, year])
}
